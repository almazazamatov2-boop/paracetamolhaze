# Twitch App (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# Your Railway domain (без / в конце)
BASE_URL=https://your-app.railway.app

# PostgreSQL — Railway подставляет автоматически при добавлении плагина
DATABASE_URL=postgresql://user:pass@host:5432/db

# Порт (Railway сам задаёт $PORT, не нужно менять)
APP_PORT=3000
